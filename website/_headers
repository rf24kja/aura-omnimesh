# Cloudflare Pages headers (https://developers.cloudflare.com/pages/configuration/headers/)
# The site is a single self-contained static page — zero external requests,
# so the CSP can be strict. 'unsafe-inline' is required for the inlined
# <style> and the JSON-LD/SVG; no external script/style/img is allowed.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), camera=(), microphone=(), interest-cohort=()
  Content-Security-Policy: default-src 'none'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'

# The Flutter web light client under /app needs a working-app CSP: its own
# scripts (plus the inline ort bootstrap), wasm execution, blob: workers,
# same-origin fetches (model proxy, assets), the engine's Roboto fetch from
# fonts.gstatic.com (no fonts are bundled), and ws:/wss: so the light client
# can reach the user-supplied ?bridge=ws://<lan-ip>:<port> Core Node.
# NOTE: over HTTPS the browser still blocks insecure ws:// as mixed content —
# real LAN pairing needs the client served over http OR a wss:// Core Node;
# this CSP unblocks the http-self-hosted and wss cases. Everything else stays
# as strict as the marketing page.
/app/*
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' ws: wss: https://fonts.gstatic.com; worker-src 'self' blob:; manifest-src 'self'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'

# The bare /app/ document itself — the splat above requires at least one
# character after the slash, and THIS is the HTML whose CSP governs the app.
/app/
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' ws: wss: https://fonts.gstatic.com; worker-src 'self' blob:; manifest-src 'self'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'

# Long-cache immutable-ish assets; HTML stays revalidated so edits ship fast.
/*.html
  Cache-Control: public, max-age=0, must-revalidate
