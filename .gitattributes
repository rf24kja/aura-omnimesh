# Large binary assets tracked via Git LFS (model weights, wasm runtime).
*.onnx filter=lfs diff=lfs merge=lfs -text
*.wasm filter=lfs diff=lfs merge=lfs -text
# website/app is the DEPLOYED web build: Cloudflare Pages git builds do not
# smudge LFS pointers, so anything under it must be plain git blobs (each
# file is under both GitHub's and Pages' per-file limits).
website/app/** -filter -diff -merge
website/app/**/*.wasm -filter -diff -merge -text
assets/models/xlmr_vocab_trimmed_v1.tsv filter=lfs diff=lfs merge=lfs -text
# Normalize line endings for text so the repo is stable across OSes.
*.dart text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.kt text eol=lf
*.swift text eol=lf
assets/models/xlmr_unigram_vocab.tsv filter=lfs diff=lfs merge=lfs -text
